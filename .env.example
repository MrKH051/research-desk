# ============================================================
#  Research Desk — configuration
#  Copy this file to ".env" and fill in your own values.
#  The ".env" file is private and is NEVER uploaded to GitHub.
# ============================================================

# --- Web server ---
PORT=3000

# --- Payment rail ---
# "sim"  = simulated escrow, runs fully offline, no accounts needed (default)
# "croo" = real CROO Agent Protocol on Base (needs the values below)
RAIL=sim

# --- AI brain (free) ---
# Default provider is Groq (free, fast). Get a key at https://console.groq.com/keys
# It is OpenAI-compatible, so you can swap in any compatible provider by changing the URL/model.
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
LLM_API_KEY=

# --- CROO (only needed when RAIL=croo) ---
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws

# One SDK key per agent profile (from the CROO dashboard).
CROO_ORCHESTRATOR_SDK_KEY=   # Atlas (the buyer that hires & pays)
CROO_RESEARCH_SDK_KEY=       # Argus
CROO_WRITER_SDK_KEY=         # Calliope
CROO_VERIFIER_SDK_KEY=       # Themis

# The orchestrator hires each worker by its SERVICE id (from the dashboard).
CROO_RESEARCH_SERVICE_ID=
CROO_WRITER_SERVICE_ID=
CROO_VERIFIER_SERVICE_ID=

# How much (test) USDC was deposited into Atlas's wallet (dashboard display only).
CROO_START_BALANCE=50

# Optional: override the chain RPC (defaults to Base mainnet inside the SDK).
# CROO_RPC_URL=
